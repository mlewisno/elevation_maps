{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git ls-tree:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git rm:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(ALLOW_LARGE=1 git commit:*)",
      "Bash(ALLOW_MULTI=1 git commit:*)",
      "Bash(ALLOW_LARGE=1 ALLOW_MULTI=1 git commit:*)",
      "Bash(gh api:*)",
      "Bash(gh issue:*)",
      "Bash(gh label:*)",
      "Bash(gh pr:*)",
      "Bash(gh run:*)",
      "Bash(scripts/hooks/lib/pr-comments.sh:*)",
      "Bash(scripts/hooks/lib/change-size.sh:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Skill(*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ],
    "deny": [
      "Bash(gh pr merge:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Read(**/*secret*)",
      "Read(**/*credentials*)",
      "Read(~/.ssh/*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Edit(**/Gemfile.lock)",
      "Edit(**/package-lock.json)",
      "Edit(**/go.sum)",
      "Edit(**/yarn.lock)",
      "Edit(**/poetry.lock)",
      "Edit(**/pnpm-lock.yaml)"
    ]
  }
}
