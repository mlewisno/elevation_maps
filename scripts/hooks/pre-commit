#!/usr/bin/env bash
#
# pre-commit - Run fast validators on staged changes
#
# Runs configured validators before commit.
# Install with: scripts/hooks/install.sh
#
# Exit codes:
#   0 - All validators passed
#   1 - One or more validators failed

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Find the hooks directory (works whether run from .git/hooks or directly)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# If running from .git/hooks, find the actual scripts directory
if [[ "$SCRIPT_DIR" == *".git/hooks"* ]]; then
    REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
    HOOKS_DIR="$REPO_ROOT/scripts/hooks"
else
    HOOKS_DIR="$SCRIPT_DIR"
fi

VALIDATORS_DIR="$HOOKS_DIR/validators"
CONFIG_FILE="$HOOKS_DIR/config.sh"

# Default pre-commit validators
PRE_COMMIT_VALIDATORS=()

# Load config
if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
fi

# Skip if no pre-commit validators configured
if [[ ${#PRE_COMMIT_VALIDATORS[@]} -eq 0 ]]; then
    exit 0
fi

echo -e "${BOLD}Running pre-commit validators...${NC}"
echo ""

FAILED=0
PASSED=0

run_validator() {
    local name="$1"
    local script="$VALIDATORS_DIR/${name}.sh"

    if [[ ! -f "$script" ]]; then
        echo -e "${RED}Validator not found:${NC} $script"
        return 1
    fi

    if [[ ! -x "$script" ]]; then
        echo -e "${CYAN}Making validator executable:${NC} $script"
        chmod +x "$script"
    fi

    echo -e "${BOLD}[$name]${NC}"

    local exit_code=0
    "$script" || exit_code=$?

    if [[ $exit_code -eq 0 ]]; then
        PASSED=$((PASSED + 1))
        return 0
    elif [[ $exit_code -eq 2 ]]; then
        # Exit code 2 = warnings only (non-blocking)
        WARNED=$((WARNED + 1))
        return 0
    else
        # Other non-zero exit means failure
        FAILED=$((FAILED + 1))
        return 1
    fi
}

for validator in "${PRE_COMMIT_VALIDATORS[@]}"; do
    echo ""
    run_validator "$validator" || true
done

echo ""
echo -e "${BOLD}Summary:${NC}"
echo "  Passed:   $PASSED"
echo "  Failed:   $FAILED"
echo ""

if [[ $FAILED -gt 0 ]]; then
    echo -e "${RED}Pre-commit checks failed.${NC}"
    echo "Fix the issues above or use --no-verify to bypass (not recommended)."
    exit 1
fi

echo -e "${GREEN}All pre-commit checks passed.${NC}"
exit 0
